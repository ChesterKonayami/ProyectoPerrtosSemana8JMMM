<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<appSettings>
		<add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
	</appSettings>

	<system.web>
		<compilation debug="true" />
	</system.web>

	<!--
  Configuración del servicio WCF.
  Este servicio será consumido posteriormente por el proyecto MVC.
  -->

	<system.serviceModel>

		<services>

			<service name="ProyectoPerritosServicioWCF.DogService">

				<!-- Endpoint principal -->
				<endpoint
				  address=""
				  binding="basicHttpBinding"
				  contract="ProyectoPerritosServicioWCF.IDogService">

					<identity>
						<dns value="localhost" />
					</identity>

				</endpoint>

				<!-- Endpoint de metadatos -->
				<endpoint
				  address="mex"
				  binding="mexHttpBinding"
				  contract="IMetadataExchange" />

				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:8733/Design_Time_Addresses/ProyectoPerritosServicioWCF/DogService/" />
					</baseAddresses>
				</host>

			</service>

		</services>

		<behaviors>

			<serviceBehaviors>

				<behavior>

					<!-- Permite consultar metadatos del servicio -->
					<serviceMetadata
					  httpGetEnabled="true"
					  httpsGetEnabled="true" />

					<!-- Muestra errores detallados durante desarrollo -->
					<serviceDebug
					  includeExceptionDetailInFaults="false" />

				</behavior>

			</serviceBehaviors>

		</behaviors>

	</system.serviceModel>

</configuration>